# CI environment — dummy values for services not called during E2E/smoke tests.
# DB and Redis URLs point to Docker Compose service names.

NODE_ENV=production

# Database — Docker Compose service names
DATABASE_URL=postgresql://app_user:app@db:5432/analytics
DATABASE_ADMIN_URL=postgresql://app_admin:app@db:5432/analytics

# Redis
REDIS_URL=redis://redis:6379

# Auth — dummy values, no real OAuth calls in CI
JWT_SECRET=ci-test-secret-that-is-at-least-32-chars-long-for-validation
GOOGLE_CLIENT_ID=ci-dummy-google-client-id
GOOGLE_CLIENT_SECRET=ci-dummy-google-client-secret

# AI — dummy key, seed summary is pre-cached so no Claude calls needed
CLAUDE_API_KEY=sk-ant-ci-dummy-key-not-used
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Stripe — dummy values, no payment flows in E2E. sk_live_ prefix satisfies
# the production-mode config guard; actual Stripe calls don't happen in CI.
STRIPE_SECRET_KEY=sk_live_ci_dummy_key_not_real
STRIPE_WEBHOOK_SECRET=whsec_ci_dummy_secret
STRIPE_PRICE_ID=price_ci_dummy_id

# App
APP_URL=http://localhost:3000
PORT=3001

# Disable rate limiters in CI — parallel Playwright workers blow 60/min public
# limit on dashboard routes otherwise. Rate limiter tests still cover the logic.
DISABLE_RATE_LIMIT=true
