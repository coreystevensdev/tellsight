{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count[2m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "HTTP Error Rate (5xx/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{status=~\"5..\"}[2m]))",
          "legendFormat": "5xx errors"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latency Percentiles (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "AI Summary Rate (summaries/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(ai_summary_total[1m])) by (tier, outcome)",
          "legendFormat": "{{tier}} {{outcome}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "AI Token Consumption (tokens/min)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(ai_tokens_used_total[1m])) by (direction)",
          "legendFormat": "{{direction}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "SSE Active Streams",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sse_active_streams",
          "legendFormat": "active"
        }
      ]
    },
    {
      "id": 7,
      "title": "Rate Limit Hits (hits/min)",
      "type": "stat",
      "gridPos": { "x": 6, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(rate_limit_hits_total[1m]))",
          "legendFormat": "hits/min"
        }
      ]
    },
    {
      "id": 8,
      "title": "Circuit Breaker State (1=open)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "circuit_breaker_open",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Cost Budget Exceeded (total)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 24, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(ai_cost_budget_exceeded_total)",
          "legendFormat": "budget exceeded"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "tags": ["tellsight"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Data source"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Tellsight",
  "uid": "tellsight-main",
  "version": 1
}
