{
  "name": "tellsight",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "screenshots": "pnpm -C apps/api exec tsx ../../scripts/generate-screenshots.ts",
    "eval": "if [ -f .env ]; then set -a; . ./.env; set +a; fi; pnpm -C apps/api exec tsx ../../scripts/eval-summaries.ts",
    "test:eval": "pnpm -C apps/api exec vitest run -c ../../scripts/vitest.config.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "jose": "^6.2.3",
    "postgres": "^3.4.9",
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.64.0"
  }
}
