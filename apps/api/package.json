{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias && cp -r src/services/curation/config dist/services/curation/config",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "test": "NODE_OPTIONS='--max-old-space-size=4096' vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:run": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@sentry/node": "^10.49.0",
    "bullmq": "^5.74.1",
    "cookie-parser": "^1.4.7",
    "csv-parse": "^6.1.0",
    "drizzle-orm": "^0.45.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.0",
    "jose": "^6.0.0",
    "multer": "^2.1.0",
    "pino": "^10.3.0",
    "pino-http": "^11.0.0",
    "postgres": "^3.4.0",
    "prom-client": "^15.1.3",
    "rate-limiter-flexible": "^9.1.1",
    "resend": "^6.12.0",
    "shared": "workspace:*",
    "simple-statistics": "^7.8.8",
    "stripe": "^20.4.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.0",
    "pino-pretty": "^13.0.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  }
}
