# Database
DATABASE_URL=postgresql://app_user:app@localhost:5432/analytics
DATABASE_ADMIN_URL=postgresql://app_admin:app@localhost:5432/analytics

# Redis
REDIS_URL=redis://localhost:6379

# AI Service (optional — seed data mode works without a real key)
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
STRIPE_PRICE_ID=price_your-pro-plan-price-id

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# JWT
JWT_SECRET=your-secret-key-at-least-32-characters-long

# Application
APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3001
