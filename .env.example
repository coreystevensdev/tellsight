# Database
DATABASE_URL=postgresql://app_user:app@localhost:5432/analytics
DATABASE_ADMIN_URL=postgresql://app_admin:app@localhost:5432/analytics

# Redis
REDIS_URL=redis://localhost:6379

# AI Service (optional, seed data mode works without a real key)
# The offline eval harness (`pnpm eval`) is the exception: it calls the live API,
# so it needs a REAL key here plus a complete .env (config.ts validates the whole
# schema at boot). Without a key the harness exits 0 with "skipping", not a failure.
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
STRIPE_PRICE_ID=price_your-pro-plan-price-id

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# JWT
JWT_SECRET=your-secret-key-at-least-32-characters-long

# QuickBooks Integration (optional, app runs without these)
# QUICKBOOKS_CLIENT_ID=your-intuit-app-client-id
# QUICKBOOKS_CLIENT_SECRET=your-intuit-app-client-secret
# QUICKBOOKS_REDIRECT_URI=http://localhost:3001/integrations/quickbooks/callback
# QUICKBOOKS_ENVIRONMENT=sandbox
# ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# Email service (Story 9.1, provider abstraction)
# EMAIL_FROM_ADDRESS and EMAIL_MAILING_ADDRESS are REQUIRED, no defaults. The mailing
# address must be your real physical address (CAN-SPAM 15 USC §7704). Placeholder
# values ("@example.com", "1234 Main St") are rejected in production at boot.
EMAIL_FROM_ADDRESS=insights@kiln.local
EMAIL_MAILING_ADDRESS="Your Company, 123 Real Street, City, State ZIP"
# Console provider is the default outside production, logs every send instead of delivering.
# EMAIL_PROVIDER=resend is required when NODE_ENV=production (enforced at boot).
# EMAIL_PROVIDER=console
# RESEND_API_KEY=re_your-resend-api-key
# Svix-shared secret from the Resend dashboard webhook config (Story 9.4).
# Required at boot when EMAIL_PROVIDER=resend in production. Without it, the
# /webhooks/resend route rejects every request and bounce/complaint feedback
# stays dark.
# RESEND_WEBHOOK_SECRET=whsec_your-svix-shared-secret
# EMAIL_FROM_NAME="Kiln Insights"
# EMAIL_REPLY_TO=hello@kiln.app
# EMAIL_CAPTURE_DIR=.tmp/email-captures   # optional: dev only, writes rendered HTML to disk

# Sentry (runtime DSN is public; upload vars are build-time only)
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>
# SENTRY_ORG=your-sentry-org-slug
# SENTRY_PROJECT=your-sentry-project-slug
# SENTRY_AUTH_TOKEN=sntrys_... (CI/deploy secret, never commit)

# Application
APP_URL=http://localhost:3000
# Externally-reachable API origin. Used for URLs dereferenced outside the BFF
# (e.g., the digest open-pixel hit by recipients' email clients). Production
# must point at the public API host; localhost defaults are rejected at boot.
PUBLIC_API_URL=http://localhost:3001
NODE_ENV=development
PORT=3001
