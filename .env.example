# Database
DATABASE_URL=postgresql://app_user:app@localhost:5432/analytics
DATABASE_ADMIN_URL=postgresql://app_admin:app@localhost:5432/analytics

# Redis
REDIS_URL=redis://localhost:6379

# AI Service (optional — seed data mode works without a real key)
CLAUDE_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
STRIPE_PRICE_ID=price_your-pro-plan-price-id

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# JWT
JWT_SECRET=your-secret-key-at-least-32-characters-long

# QuickBooks Integration (optional — app runs without these)
# QUICKBOOKS_CLIENT_ID=your-intuit-app-client-id
# QUICKBOOKS_CLIENT_SECRET=your-intuit-app-client-secret
# QUICKBOOKS_REDIRECT_URI=http://localhost:3001/integrations/quickbooks/callback
# QUICKBOOKS_ENVIRONMENT=sandbox
# ENCRYPTION_KEY=generate-with-openssl-rand-hex-32

# Email service (Story 9.1 — provider abstraction)
# Console provider is the default outside production — logs every send instead of delivering.
# EMAIL_PROVIDER=resend is required when NODE_ENV=production (enforced at boot).
# EMAIL_PROVIDER=console
# RESEND_API_KEY=re_your-resend-api-key
# EMAIL_FROM_ADDRESS=insights@kiln.example
# EMAIL_FROM_NAME="Kiln Insights"
# EMAIL_REPLY_TO=hello@kiln.example
# EMAIL_MAILING_ADDRESS="Kiln Insights, 1234 Main St, Denver, CO 80202, USA"
# EMAIL_CAPTURE_DIR=.tmp/email-captures   # optional: dev only — writes rendered HTML to disk

# Sentry (runtime DSN is public; upload vars are build-time only)
# NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>
# SENTRY_ORG=your-sentry-org-slug
# SENTRY_PROJECT=your-sentry-project-slug
# SENTRY_AUTH_TOKEN=sntrys_... (CI/deploy secret — never commit)

# Application
APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3001
